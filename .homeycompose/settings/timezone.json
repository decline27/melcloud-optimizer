{
  "id": "timezone",
  "title": {
    "en": "Comfort Profile Settings"
  },
  "hint": {
    "en": "Configure your comfort preferences for time-based optimizations."
  },
  "children": [
    {
      "id": "comfort_profile",
      "type": "group",
      "label": {
        "en": "Night Setback"
      },
      "children": [
        {
          "id": "night_setback_enabled",
          "type": "checkbox",
          "label": {
            "en": "Enable Night Setback"
          },
          "hint": {
            "en": "Lower the heating target during sleeping hours. Only applies when home is occupied."
          },
          "value": false
        },
        {
          "id": "night_start_hour",
          "type": "number",
          "label": {
            "en": "Night Start Hour (0-23)"
          },
          "hint": {
            "en": "Hour when night setback begins (e.g., 22 for 10:00 PM)."
          },
          "min": 0,
          "max": 23,
          "step": 1,
          "value": 22
        },
        {
          "id": "night_end_hour",
          "type": "number",
          "label": {
            "en": "Night End Hour (0-23)"
          },
          "hint": {
            "en": "Hour when daytime band resumes (e.g., 6 for 6:00 AM)."
          },
          "min": 0,
          "max": 23,
          "step": 1,
          "value": 6
        },
        {
          "id": "comfort_lower_night",
          "type": "number",
          "label": {
            "en": "Night Lower Temperature (°C)"
          },
          "hint": {
            "en": "Minimum comfort temperature during night hours."
          },
          "min": 14,
          "max": 22,
          "step": 0.5,
          "value": 17
        },
        {
          "id": "comfort_upper_night",
          "type": "number",
          "label": {
            "en": "Night Upper Temperature (°C)"
          },
          "hint": {
            "en": "Maximum comfort temperature during night hours. Keep 1-2°C below daytime upper."
          },
          "min": 15,
          "max": 23,
          "step": 0.5,
          "value": 19
        }
      ]
    }
  ]
}
