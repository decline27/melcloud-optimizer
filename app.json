{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.melcloud.optimize",
  "version": "1.0.8",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "MELCloud Optimizer"
  },
  "description": {
    "en": "Optimize your MELCloud heat pump based on electricity prices and weather"
  },
  "category": [
    "climate"
  ],
  "permissions": [
    "homey:manager:api"
  ],
  "author": {
    "name": "Kjetil Vetlejord",
    "email": "decline27@gmail.com"
  },
  "images": {
    "large": "/assets/images/large.png",
    "small": "/assets/images/small.png"
  },
  "brandColor": "#1E88E5",
  "support": "https://github.com/decline27/melcloud-optimizer/issues",
  "api": {
    "getTestLogging": {
      "method": "GET",
      "path": "/testLogging"
    },
    "getRunHourlyOptimizer": {
      "method": "GET",
      "path": "/runHourlyOptimizer"
    },
    "getRunWeeklyCalibration": {
      "method": "GET",
      "path": "/runWeeklyCalibration"
    },
    "getCheckCronStatus": {
      "method": "GET",
      "path": "/getCheckCronStatus"
    },
    "getUpdateCronStatus": {
      "method": "GET",
      "path": "/getUpdateCronStatus"
    },
    "getStartCronJobs": {
      "method": "GET",
      "path": "/getStartCronJobs"
    },
    "getDeviceList": {
      "method": "GET",
      "path": "/getDeviceList"
    },
    "getThermalModelData": {
      "method": "GET",
      "path": "/getThermalModelData"
    },
    "getCOPData": {
      "method": "GET",
      "path": "/getCOPData"
    },
    "getWeeklyAverageCOP": {
      "method": "GET",
      "path": "/getWeeklyAverageCOP"
    },
    "updateOptimizerSettings": {
      "method": "GET",
      "path": "/updateOptimizerSettings"
    },
    "getMelCloudStatus": {
      "method": "GET",
      "path": "/getMelCloudStatus"
    },
    "getTibberStatus": {
      "method": "GET",
      "path": "/getTibberStatus"
    },
    "runSystemHealthCheck": {
      "method": "GET",
      "path": "/runSystemHealthCheck"
    },
    "getMemoryUsage": {
      "method": "GET",
      "path": "/getMemoryUsage"
    },
    "runThermalDataCleanup": {
      "method": "GET",
      "path": "/runThermalDataCleanup"
    }
  },
  "settings": [
    {
      "id": "comfort_profile_enabled",
      "type": "checkbox",
      "label": {
        "en": "Enable Comfort Profile"
      },
      "hint": {
        "en": "Enable optimization based on day/night comfort preferences."
      },
      "value": true
    },
    {
      "id": "comfort_day_start_hour",
      "type": "number",
      "label": {
        "en": "Day Start Hour"
      },
      "hint": {
        "en": "Hour when 'day' comfort period begins (0-23)."
      },
      "value": 7,
      "attr": {
        "min": 0,
        "max": 23
      }
    },
    {
      "id": "comfort_day_end_hour",
      "type": "number",
      "label": {
        "en": "Day End Hour"
      },
      "hint": {
        "en": "Hour when 'day' comfort period ends (0-23)."
      },
      "value": 22,
      "attr": {
        "min": 0,
        "max": 23
      }
    },
    {
      "id": "comfort_night_temp_reduction",
      "type": "number",
      "label": {
        "en": "Night Temperature Reduction"
      },
      "hint": {
        "en": "Degrees (°C) to reduce target temperature during 'night' period."
      },
      "value": 2,
      "attr": {
        "min": 0,
        "max": 5,
        "step": 0.5
      }
    },
    {
      "id": "comfort_preheat_hours",
      "type": "number",
      "label": {
        "en": "Pre-heat Hours"
      },
      "hint": {
        "en": "Hours before 'day' period starts to begin pre-heating."
      },
      "value": 1,
      "attr": {
        "min": 0,
        "max": 3,
        "step": 0.5
      }
    }
  ]
}